# Supabase Configuration
# For OFFLINE SUPABASE, point this to the Nginx reverse proxy running on port 3000.
# Example: VITE_SUPABASE_URL=http://100.106.152.51:3000/supabase-api
# You can find the Anon Key by running `npx supabase status` on the remote VM.
VITE_SUPABASE_URL=http://YOUR_VM_IP:3000/supabase-api
VITE_SUPABASE_PUBLISHABLE_KEY=your_local_anon_key
SUPABASE_URL=http://YOUR_VM_IP:3000/supabase-api
SUPABASE_PUBLISHABLE_KEY=your_local_anon_key

# Local AI Configuration (Ollama)
# By default, docker-compose uses http://ollama:11434
# and pulls llama3. You can set it to qwen2.5:7b or similar.
OLLAMA_MODEL=llama3

# Fallback AI (if you don't use Ollama)
# OPENAI_API_KEY=sk-...
# LOVABLE_API_KEY=lovable-...

# Security
# Comma-separated list of allowed email domains for signup.
# E.g. "gfc.corp,gfc.com". Leave empty to allow any domain.
VITE_ALLOWED_SIGNUP_DOMAINS=
